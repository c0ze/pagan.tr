{
  "name": "pagan-tr",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "res:build": "rescript build",
    "res:clean": "rescript clean",
    "res:dev": "rescript build -w",
    "dev": "rescript build && vite --config config/vite.config.js",
