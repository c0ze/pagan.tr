    "preview": "vite preview --config config/vite.config.js"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "rescript": "^11.1.0",
    "@rescript/react": "^0.13.0",
    "@rescript/core": "^1.6.0",
    "vite": "^5.4.19",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6"
  }
}
